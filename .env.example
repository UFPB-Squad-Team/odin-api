# ─── Database ────────────────────────────────────────────────────────────────
MONGO_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"
DATABASE_NAME="odin_db"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development   # development | staging | production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Lista de origens permitidas, separadas por vírgula.
# Produção: use apenas os domínios reais, sem wildcard.
# Exemplo multi-origem: https://app.seudominio.com,https://admin.seudominio.com
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# ─── Pagination ───────────────────────────────────────────────────────────────
MAX_PAGE_SIZE=100
MAX_OFFSET_RECORDS=50000
USE_ESTIMATED_TOTAL=true
